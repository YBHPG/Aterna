# Настройки PostgreSQL
POSTGRES_USER=my_db_user
POSTGRES_PASSWORD=my_super_secret_password
POSTGRES_DB=futurelater_db

# Настройки MongoDB
MONGO_INITDB_ROOT_USERNAME=mongo_root_user
MONGO_INITDB_ROOT_PASSWORD=mongo_root_password

# Строки подключения для Backend
POSTGRES_URI=postgresql://my_db_user:my_super_secret_password@postgres:5432/futurelater_db
MONGODB_URI=mongodb://mongo_root_user:mongo_root_password@mongodb:27017/admin